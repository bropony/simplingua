# Frontend Environment Variables Example
# Copy this file to .env and update with your production values

# API URL for production (REQUIRED for production deployment)
# This tells the frontend where to find the backend API
# Development: http://localhost:8000 (default)
# Production: https://your-domain.com
NEXT_PUBLIC_API_URL=https://simplingua.mahanzhou.com

# Note: The frontend runs behind nginx reverse proxy.
# API requests go through nginx to the backend at localhost:8000.
# However, for the Next.js client-side code to make correct API calls,
# NEXT_PUBLIC_API_URL must be set to your public domain.
