# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/simplingua

# JWT secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me-to-a-random-secret

# Admin accounts (format: username:password_hash,username2:password_hash2)
# For security, use bcrypt hashes. Generate with:
#   node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('your-password', 12))"
# Plaintext passwords are supported but will log a warning.
ADMIN_ACCOUNTS=admin:$2a$12$replace_with_your_bcrypt_hash_here

# App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
