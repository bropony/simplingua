# Application Environment
ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://simplingua:dev_password@localhost:5432/simplingua_dev
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET=dev_secret_change_in_production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Provider Configuration
AI_DEFAULT_PROVIDER=deepseek

# DeepSeek (Default)
AI_DEEPSEEK_API_KEY=your_deepseek_api_key_here
AI_DEEPSEEK_MODEL=deepseek-chat
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (Optional)
AI_OPENAI_API_KEY=your_openai_api_key_here
AI_OPENAI_MODEL=gpt-4o
AI_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Optional)
AI_ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Local / Ollama (Optional)
AI_LOCAL_BASE_URL=http://localhost:11434
AI_LOCAL_MODEL=llama3.2

# Vector Embeddings
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# Rate Limiting
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_USER=100
RATE_LIMIT_PERIOD_SECONDS=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
