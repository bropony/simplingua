# =============================================================================
# Simplingua Production Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your production values
#
# SECURITY WARNING: Keep these files secure and never commit to version control!
# =============================================================================

# =============================================================================
# Backend Configuration
# =============================================================================

# Application
ENV=production
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Database (Generate strong random password)
# Use: openssl rand -base64 32
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PRODUCTION
# Note: For VPS deployment without Docker, use 'localhost' instead of 'postgres'
DATABASE_URL=postgresql://simplingua:${DB_PASSWORD}@localhost:5432/simplingua_prod

# Database connection pooling
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# JWT Authentication (Generate strong secret)
# Use: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_STRONG_SECRET_IN_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# AI Provider Configuration
# =============================================================================

# Chat AI Configuration
# Default chat AI provider (deepseek|openai|anthropic|local)
CHAT_AI_DEFAULT_PROVIDER=deepseek

# DeepSeek Chat Configuration
AI_DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
AI_DEEPSEEK_MODEL=deepseek-chat
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI Chat Configuration (Optional)
AI_OPENAI_API_KEY=sk-your-openai-api-key-here
AI_OPENAI_MODEL=gpt-4o
AI_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Chat Configuration (Optional)
AI_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
AI_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Local AI Chat Configuration (Optional - Ollama, LM Studio)
AI_LOCAL_BASE_URL=http://localhost:11434
AI_LOCAL_MODEL=llama3.2

# Embedding AI Configuration
# Default embedding AI provider (deepseek|openai|sentencetransformer|local)
EMBEDDING_AI_DEFAULT_PROVIDER=openai

# DeepSeek Embedding Configuration
EMBEDDING_DEEPSEEK_MODEL=deepseek-embeddings
EMBEDDING_DEEPSEEK_DIMENSION=1024

# OpenAI Embedding Configuration
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
EMBEDDING_OPENAI_DIMENSION=1536

# SentenceTransformer Embedding Configuration (Local models)
EMBEDDING_SENTENCETRANSFORMER_MODEL=moka-ai/m3e-base
EMBEDDING_SENTENCETRANSFORMER_DIMENSION=768

# Local Embedding Configuration (Optional - Ollama, LM Studio with embedding support)
EMBEDDING_LOCAL_MODEL=nomic-embed-text
EMBEDDING_LOCAL_DIMENSION=768

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# Anonymous users (not logged in)
RATE_LIMIT_ANONYMOUS=30

# Authenticated users
RATE_LIMIT_USER=100

# Rate limit period in seconds
RATE_LIMIT_PERIOD_SECONDS=60

# =============================================================================
# Frontend Configuration
# =============================================================================

# Frontend API URL (must be HTTPS for production)
NEXT_PUBLIC_API_URL=https://yourdomain.com

# =============================================================================
# CORS Configuration
# =============================================================================

# Comma-separated list of allowed origins
# For production: use your actual domain (only include www if you have DNS configured for it)
CORS_ORIGINS=https://yourdomain.com

# =============================================================================
# Domain Configuration
# =============================================================================

# Your domain name
DOMAIN=yourdomain.com

# Contact email for SSL (Let's Encrypt)
SSL_EMAIL=admin@yourdomain.com

# =============================================================================
# Monitoring Configuration (Optional)
# =============================================================================

# Sentry DSN for error tracking (optional)
#SENTRY_DSN=

# Application name for monitoring
APP_NAME=Simplingua
APP_VERSION=1.0.0

# =============================================================================
# Deployment Notes
# =============================================================================

# 1. Generate secure secrets:
#    openssl rand -base64 64  # for JWT_SECRET
#    openssl rand -base64 32  # for DB_PASSWORD
#
# 2. Replace placeholder values above with actual values
#
# 3. Make sure .env file has correct permissions:
#    chmod 600 .env  # Only owner can read/write
#
# 4. Database tables are created automatically on first startup via init_db()
#    No manual migrations needed
#
# 5. SSL certificates will be automatically obtained by certbot
#    First request may fail until certificates are available
#    Certificates are stored in nginx/ssl/ directory
#
# 6. External access:
#    Users access via: https://yourdomain.com (port 443)
#    HTTP redirects to HTTPS automatically
#    Internal ports (3000, 8000, 5432) are localhost-only
# =============================================================================
